' Rel(client_while, server_client_handling_thread, "Sends error code")
' else check succeeded
' 	Rel(client_while, server_client_handling_thread, "Sends 8 bytes as file size")
' 	loop
' 		Rel(client_while, server_client_handling_thread, "Sends 8192-byte chunk until the whole file is streamed")
' 	end
' 	Rel(client_while, server_client_handling_thread, "Sends 'ok'")
' end
' Rel(server_client_handling_thread, admin, "Shows 'download completed' or error code to user")


SHOW_LEGEND()
@enduml